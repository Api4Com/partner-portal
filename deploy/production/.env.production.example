# .env.production — env de RUNTIME do portal (tools1). Copie para
# .env.production (sem .example) ao lado do compose, no host.
#
# O Nitro lê NUXT_PUBLIC_* em runtime e sobrescreve o runtimeConfig. Trocar URL
# NÃO exige rebuild — edite e `docker compose up -d`.

# BFF visto pelo NAVEGADOR (via nginx + wildcard cert):
NUXT_PUBLIC_BFF_BASE=https://partners-bff.api4com.com

# BFF no SSR (server→server na mesma rede platform_shared) — evita hairpin no nginx.
# Sobrescreve runtimeConfig.bffInternalBase (privado). Ausente => cai no público acima.
NUXT_BFF_INTERNAL_BASE=http://partner-portal-bff-prod:3000

# reCAPTCHA v3 (action "signup") — chave PÚBLICA de PRODUÇÃO (registrada p/ partners.api4com.com).
# Sem isto, o nuxt.config cai na chave de teste do Google (aceita tudo). NÃO deixe assim em prod.
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=<PREENCHER_RECAPTCHA_PROD>

# Supabase (roadmap) DESLIGADO por ora — deixe ausente (roadmap degrada p/ vazio,
# sem quebrar o resto). Para ligar depois, definir NUXT_PUBLIC_SUPABASE_URL/KEY.
# NUXT_PUBLIC_SUPABASE_URL=
# NUXT_PUBLIC_SUPABASE_KEY=
